@model IEnumerable<ControlAcademicMvc.Models.Estudiante>

@{
    ViewData["Title"] = "Listado de Estudiantes";
}

<h2>Listado de Estudiantes</h2>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Carné</th>
            <th>Nombre</th>
            <th>Promedio</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var estudiante in Model)
        {
            <tr>
                <td>@estudiante.Carne</td>
                <td>@estudiante.Nombre</td>
                <td>@estudiante.Promedio</td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Registrar" class="btn btn-primary">Registrar nuevo estudiante</a>